st_drop_geometry() %>%
filter(test == 1) %>%
summarize(
h_ag = sum(hmarg_length * hmarg_length_agri_nlcd_percent),
h_nat = sum(hmarg_length * hmarg_length_natural_percent)
)
culverts_cmb_gm %>%
st_drop_geometry() %>%
filter(test == 1) %>%
summarize(
h_ag = sum(hmarg_length * hmarg_length_agri_nlcd_percent/100),
h_nat = sum(hmarg_length * hmarg_length_natural_percent/100)
)
